DATABASE_PATH=data/weather_forecasts.sqlite3

FORECAST_CITIES=Los Angeles,Buenos Aires,London,Hong Kong
OPEN_METEO_FORECAST_DAYS=3
OPEN_METEO_DAILY_VARIABLE=temperature_2m_max
OPEN_METEO_ENDPOINT=https://api.open-meteo.com/v1/forecast

# Historical forecast-skill backtest. A preceding-day 12:00 UTC ECMWF run
# covers the full target local day for the supported cities.
BACKTEST_MODEL=ecmwf_ifs
BACKTEST_RUN_HOUR_UTC=12
BACKTEST_WORKERS=2
OPEN_METEO_SINGLE_RUN_ENDPOINT=https://single-runs-api.open-meteo.com/v1/forecast
OPEN_METEO_ARCHIVE_ENDPOINT=https://archive-api.open-meteo.com/v1/archive
