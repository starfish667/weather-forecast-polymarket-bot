# Telegram user-client credentials from https://my.telegram.org/apps
TG_API_ID=
TG_API_HASH=
TG_PHONE=

# Stored locally after first login. Do not commit the generated .session file.
TG_SESSION=weatherscan

WEATHER_SCAN_BOT_USERNAME=@weatherscan_bot
WEATHER_SCAN_CITIES=Los Angeles,Buenos Aires,London,Hong Kong
WEATHER_SCAN_COMMAND_TEMPLATE={city}
WEATHER_SCAN_TIMEOUT_SECONDS=30

DATABASE_PATH=data/weather_forecasts.sqlite3

