DATABASE_PATH=data/weather_forecasts.sqlite3

FORECAST_CITIES=Los Angeles,Buenos Aires,London,Hong Kong
OPEN_METEO_FORECAST_DAYS=3
OPEN_METEO_DAILY_VARIABLE=temperature_2m_max
OPEN_METEO_ENDPOINT=https://api.open-meteo.com/v1/forecast

# Historical forecast-skill backtest. A preceding-day 12:00 UTC ECMWF run
# covers the full target local day for the supported cities.
BACKTEST_MODEL=ecmwf_ifs
BACKTEST_RUN_HOUR_UTC=12
BACKTEST_WORKERS=2
OPEN_METEO_SINGLE_RUN_ENDPOINT=https://single-runs-api.open-meteo.com/v1/forecast
OPEN_METEO_ARCHIVE_ENDPOINT=https://archive-api.open-meteo.com/v1/archive

# Live basket execution. `--live` additionally requires WEATHER_BOT_ENABLE_LIVE=1.
# These limits apply to the entire three-leg basket, not to each leg.
LIVE_MAX_RAW_BASKET_COST=0.80
LIVE_MAX_BASKET_USD=50
LIVE_WEATHER_FEE_RATE=0.05
LIVE_EVENT_PAGE_SIZE=100
LIVE_MAX_EVENTS=20
LIVE_MAX_BASKETS_PER_ROUND=6

# AI news research. This API key is used only for 0-0.pro analysis and is
# never sent to Polymarket or used to sign an order.
ZERO_ZERO_API_KEY=
ZERO_ZERO_BASE_URL=https://api.0-0.pro/v1
ZERO_ZERO_MODEL=gpt-5.5
ZERO_ZERO_TIMEOUT_SECONDS=30
NEWS_FEEDS=
AI_MONITOR_MAX_EVENTS=50
AI_MONITOR_MAX_HEADLINES_PER_FEED=20
